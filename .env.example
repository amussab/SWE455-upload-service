# Gateway Service - Environment Variables
# Copy this file to .env and fill in your values

# API Authentication Keys
API_KEY=student-demo-key
ADMIN_API_KEY=admin-demo-key

# Application Environment
APP_ENV=development
LOG_LEVEL=INFO

# Service URLs (set when integrating with other team members)
VALIDATION_SERVICE_URL=http://validation-service:8001
DATABASE_URL=postgresql://user:password@db:5432/filevalidation

# App metadata
APP_NAME=gateway-service
APP_VERSION=1.0.0
